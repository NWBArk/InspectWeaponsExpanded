#include "common.h"
#include "inspectWeapon_dof.h"

float4 main(p_screen I) : SV_TARGET
{
	float3 img = s_image.Sample(smp_nofilter, I.tc0).rgb;
	float3 P = GetPosition(I.tc0, 0);
#ifdef INSPECT_DOF
	if (!IsUsingNVG())
	{
		// Only calculate DoF when NVG is not on.
		return Inspect_DOF(I.tc0, P, img);
	}
#endif
	return float4(img, 1.0f);
}
