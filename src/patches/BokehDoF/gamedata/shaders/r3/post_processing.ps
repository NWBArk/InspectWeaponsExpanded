#include "inspectWeapon_dof_denoise.h"

uniform float4 shader_param_8;

float4 main(p_screen I) : SV_TARGET
{
    float4 dof = samplero_pepero.SampleLevel(smp_nofilter, I.tc0, 0);

    int nvgGeneration = 0;
#ifdef BEEFS_NVG
	nvgGeneration = (int)(clamp(floor(shader_param_8.x), 0.0f, 3.0f));
#endif

    if (nvgGeneration != 0)
    {
        // Don't do anything if NVG is on.
        return float4(dof.rgb, 1.0f);
    }

#ifdef INSPECT_DOF
    // When using our own DoF, alpha channel of the DoF buffer is CoC.
    return float4(Inspect_DOF_Denoise(I.tc0, dof), 1.0f);
#else
    return dof;
#endif
}